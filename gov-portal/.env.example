# GovPortal Environment Configuration
# Copy this file to .env and adjust the values

# Nextcloud server URL (without trailing slash)
VITE_NEXTCLOUD_URL=http://localhost:8080

# OAuth2 Client ID (create this in Nextcloud Admin > Security > OAuth2)
VITE_OAUTH_CLIENT_ID=gov-portal-client

# Optional: Enable debug mode
VITE_DEBUG=false
