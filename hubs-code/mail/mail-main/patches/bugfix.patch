+	// itsl: dark theme for SDK message iframes only
+	// SDK messages are markdown-derived HTML (via javamw Flexmark) — guaranteed
+	// no colors or backgrounds. Other types (Internal, Secure Email) may contain
+	// rich HTML with sender-chosen colors that would break on dark backgrounds.
+	try {
+		const frame = window.frameElement
+		if (!frame) return
+		const envelope = frame.closest('[data-itsl-message-type]')
+		if (envelope?.dataset.itslMessageType !== 'sdk_message') return
+
+		const parentStyle = parent.getComputedStyle(parent.document.documentElement)
+		const bg = parentStyle.getPropertyValue('--color-main-background').trim()
+		const fg = parentStyle.getPropertyValue('--color-main-text').trim()
+		if (bg) {
+			document.documentElement.style.backgroundColor = bg
+			document.body.style.backgroundColor = bg
+		}
+		if (fg) document.body.style.color = fg
+	} catch (e) { /* cross-origin or sandboxed — ignore */ }
 })
