#!/usr/bin/env bash
#
# regen-htaccess — rewrite the HMR-PROXY block in /var/www/html/.htaccess
# from currently-reachable sidecar-<app> containers.
#
# Regenerate-from-running: discover apps via /srv/apps (apps/ bind-mounted
# into NC), TCP-probe sidecar-<app>:3000 under a 1s timeout. Only HMR-mode
# sidecars bind 3000 (webpack-dev-server); watch mode does not — so the
# probe selects exactly the sidecars the proxy block needs. No docker
# socket. The 1s ceiling matters: docker's embedded DNS forwards unknown
# service names upstream and can block tens of seconds; a TCP connect under
# `timeout` short-circuits both DNS and connect at once.

set -euo pipefail
# nullglob — without it, an empty /srv/apps/ makes `for ... in /srv/apps/*/`
# iterate the literal unmatched pattern. Same idiom as deps.sh, discover-apps.
shopt -s nullglob

DRY_RUN=0
case "${1:-}" in
    --dry-run) DRY_RUN=1 ;;
    "") ;;
    *) echo "ERROR: unknown argument: $1 (only --dry-run is supported)" >&2; exit 2 ;;
esac

HTACCESS=/var/www/html/.htaccess

reachable=()
for app_dir in /srv/apps/*/; do
	app=$(basename "$app_dir")
	[ "$app" = "server" ] && continue
	[ -d "$app_dir/upstream" ] || continue
	if timeout 1 bash -c ": </dev/tcp/sidecar-$app/3000" 2>/dev/null; then
		reachable+=("$app")
	fi
done

# emit_block — single source of the proxy block, shared by the write and
# dry-run paths so status.sh's drift check (--dry-run) byte-compares against
# what the rewrite would produce for the same reachable[].
emit_block() {
	echo "### HMR-PROXY-START ###"
	echo "# Auto-generated by /usr/local/bin/regen-htaccess"
	echo "RewriteEngine On"
	for app in "${reachable[@]}"; do
		# WebSocket upgrade for the HMR client ↔ WDS handshake.
		echo "RewriteCond %{HTTP:Upgrade} websocket [NC]"
		echo "RewriteRule ^apps-extra/${app}/ws(.*) ws://sidecar-${app}:3000/apps-extra/${app}/ws\$1 [P,L]"
		# JS bundle from WDS memory (HMR runtime injected), not on-disk .build/js/.
		echo "RewriteRule ^apps-extra/${app}/js/(.*) http://sidecar-${app}:3000/apps-extra/${app}/js/\$1 [P,L]"
	done
	echo "### HMR-PROXY-END ###"
}

if [ "$DRY_RUN" = "1" ]; then
	# Empty reachable[] → emit nothing, exit 0 — mirrors the write path's
	# "strip then exit without emitting" so status.sh compares empty vs
	# empty and reports no drift. No HMR block is the correct state here.
	[ "${#reachable[@]}" -gt 0 ] || exit 0
	emit_block
	exit 0
fi

# Strip prior block — sed range delete is idempotent (no markers = no-op).
sed -i '/### HMR-PROXY-START ###/,/### HMR-PROXY-END ###/d' "$HTACCESS"

# No reachable sidecars — leave the block stripped; requests fall through to
# nextcloud's default routing, which serves the on-disk bundle from .build/js/.
[ "${#reachable[@]}" -gt 0 ] || exit 0

# Prepend the block so it runs before nextcloud's catch-all rewrite to
# index.php; tmp + atomic rename. Separate statements (not `&& mv`) so a
# brace-group failure trips set -e instead of being swallowed by the AND-list.
{
	emit_block
	cat "$HTACCESS"
} > "${HTACCESS}.tmp"
mv "${HTACCESS}.tmp" "$HTACCESS"
