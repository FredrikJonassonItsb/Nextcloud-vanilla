# Docker Compose environment variables for ITSL Hubs-Apps dev environment.
# Copy to .env and adjust as needed: cp .env.example .env
#
# Uncommented values are required (compose + make read from .env as the
# single source of truth). Commented values are container defaults;
# uncomment to override.

# Nextcloud version (git tag from github.com/nextcloud/server) — REQUIRED
NEXTCLOUD_VERSION=v31.0.8

# Pinned, not derived from cwd basename: make must hit the same compose
# project from the host and from inside the dev-builder, where cwd is
# /platform and basename would resolve to "platform", missing every
# hubs-apps container. Lives here so gitignored per-operator .env inherits it.
COMPOSE_PROJECT_NAME=hubs-apps

# PHP_VERSION=8.3

# Container user UID/GID — auto-detected from `id -u` / `id -g` on each
# make invocation. Set here only to override (non-host UID, or invoking
# compose directly without make).
# DEVELOPER_UID=1000
# DEVELOPER_GID=1000

# PHP_MEMORY_LIMIT=512M
# PHP_POST_MAX_SIZE=128M
# PHP_UPLOAD_MAX_FILESIZE=128M
