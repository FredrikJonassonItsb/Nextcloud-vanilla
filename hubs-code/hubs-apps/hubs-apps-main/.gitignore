apps/
.cache/
.env
# Per-app sidecar fragments generated by scripts/compose.sh, one per
# quilt app actively using a sidecar; written by `make webpack
# MODE=<hmr|watch>`, deleted by `make webpack MODE=off`. Directory
# itself is tracked via
# docker/sidecars/.gitkeep so docker's create_host_path:true default
# doesn't invent an empty root-owned host dir on first bind; only the
# *.yml content inside is gitignored.
docker/sidecars/*.yml
# Multi-root VSCode workspace file generated by scripts/workspace.sh,
# written on every `make ide-up` so the folder list tracks whatever
# apps are currently cloned. The .tmp sibling exists in flight during
# regeneration (write-then-mv pattern in the Makefile ide-up recipe);
# committed source-of-truth lives in scripts/workspace.sh.
hubs-apps.code-workspace
.hubs-apps.code-workspace.tmp
.DS_Store
__pycache__/
.pytest_cache/
