#: src-server-settings/pages/ServerSettings.vue:545
msgid "Scope"
msgstr "Scope"

#: src-server-settings/pages/ServerSettings.vue:546
msgid "Space separated list of scopes to request (e.g. profile email openid)."
msgstr "Blankstegsseparerad lista över scopes att begära (t.ex. profile email openid)."

#: src-server-settings/pages/ServerSettings.vue:551
msgid "SSN Claim"
msgstr "OIDC-attribut (claim) för personnummer"

#: src-server-settings/pages/ServerSettings.vue:552
msgid "Name of the claim in the OIDC ID token that contains the personnummer (e.g. personalNumber, preferred_username). Leave empty to use default fallback chain."
msgstr "Namn på det claim i OIDC ID-token som innehåller personnumret (t.ex. personalNumber, preferred_username). Lämna tomt för att använda standardordningen."

#: src-server-settings/pages/ServerSettings.vue:558
msgid "First Name Claim"
msgstr "OIDC-attribut (claim) för förnamn"

#: src-server-settings/pages/ServerSettings.vue:559
msgid "Name of the claim in the OIDC ID token that contains the first name (e.g. givenName, given_name). Leave empty to use default fallback chain."
msgstr "Namn på det claim i OIDC ID-token som innehåller förnamnet (t.ex. givenName, given_name). Lämna tomt för att använda standardordningen."

#: src-server-settings/pages/ServerSettings.vue:565
msgid "Last Name Claim"
msgstr "OIDC-attribut (claim) för efternamn"

#: src-server-settings/pages/ServerSettings.vue:566
msgid "Name of the claim in the OIDC ID token that contains the last name (e.g. surname, family_name). Leave empty to use default fallback chain."
msgstr "Namn på det claim i OIDC ID-token som innehåller efternamnet (t.ex. surname, family_name). Lämna tomt för att använda standardordningen."

#: src-server-settings/pages/ServerSettings.vue:573
msgid "SMS Gateway"
msgstr "SMS-integration"

#: src-server-settings/pages/ServerSettings.vue:574
msgid "Configured SMS gateway/integration used for sending text messages."
msgstr "Konfigurerad SMS-gateway/integration för att skicka textmeddelanden."

#: src-server-settings/pages/ServerSettings.vue:585
msgid "SMS Gateway Username"
msgstr "Användarnamn för sms-integrationen"

#: src-server-settings/pages/ServerSettings.vue:586
msgid "Account username for authenticating with the SMS gateway service."
msgstr "Användarnamn för autentisering mot SMS-gateway-tjänsten."

#: src-server-settings/pages/ServerSettings.vue:592
msgid "SMS Gateway Password"
msgstr "Lösenord för sms-integrationen"

#: src-server-settings/pages/ServerSettings.vue:593
msgid "Account password for authenticating with the SMS gateway service."
msgstr "Lösenord för autentisering mot SMS-gateway-tjänsten."

#: src-server-settings/pages/ServerSettings.vue:598
msgid "SMS Gateway Sender"
msgstr "Avsändare för sms"

#: src-server-settings/pages/ServerSettings.vue:599
msgid "Alphanumeric, max 11 chars, must start with a letter"
msgstr "Enbart bokstäver, max 11 tecken. Måste börja med en bokstav"

#: src-server-settings/pages/ServerSettings.vue:604
msgid "SMS message: use #ORGANIZER_NAME for organizer, #ATTENDEE_EMAIL for attendee"
msgstr "SMS-meddelande. Använd #ORGANIZER_NAME för handläggarens namn och  #ATTENDEE_EMAIL för mottagarens e-post"

#: src-server-settings/pages/ServerSettings.vue:605
msgid "Use placeholders in your message, e.g. “You have been invited by #ORGANIZER_NAME and the invitation was sent to #ATTENDEE_EMAIL.”"
msgstr "Det går att använda ersättare i texten. Till exempel så kommer \"Du har blivit inbjuden till möte av #ORGANIZER_NAME och inbjudan har skickats till #ATTENDEE_EMAIL\" skickas som \"Du har blivit inbjuden till möte av Anna och inbjudan har skickats till pelle.persson@gmail.com\""

#: src-server-settings/pages/ServerSettings.vue:611
msgid "Organizer for calendar event invitation email"
msgstr "Organisationsnamn för mötesinbjudningar"

#: src-server-settings/pages/ServerSettings.vue:612
msgid "Provide the organizer line for the calendar invitation email. Leave blank for the organizers actual name and email"
msgstr "Om det här fältet fylls i så kommer handläggarens namn döljas i ics-filen i mötesinbjudningar och istället kommer fältets innehåll att visas. Lämna blankt för att istället inkludera handläggarens namn och e-post"

#: src-server-settings/pages/ServerSettings.vue:617
msgid "Subject for calendar event invitation email"
msgstr "Ämnesrad för mötesinbjudningar"

#: src-server-settings/pages/ServerSettings.vue:618
msgid "Provide the subject line for the calendar invitation email. You may use placeholders such as #ORGANIZER_NAME and #ATTENDEE_EMAIL."
msgstr "Det går att använda ersättare i texten. Till exempel så kommer \"Du har blivit inbjuden till möte av #ORGANIZER_NAME\" skickas som \"Du har blivit inbjuden till möte av Anna\".  #ORGANIZER_NAME och #ATTENDEE_EMAIL är tillgängliga ersättare."

#: src-server-settings/pages/ServerSettings.vue:623
msgid "[HTML] Body for calendar event invitation email"
msgstr "Mall för epost-meddelande för mötesbokning [HTML]"

#: src-server-settings/pages/ServerSettings.vue:624
msgid ""
"Compose the HTML email body for the invitation. Available placeholders:\n"
"\n"
"• #INVITATION_LINK (required) - Meeting invitation link\n"
"• #TITLE - Event title\n"
"• #DESCRIPTION - Event description\n"
"• #DATE_AND_TIME - Formatted date and time\n"
"• #ACCEPT_LINK - Accept invitation link\n"
"• #DECLINE_LINK - Decline invitation link"
msgstr ""
"Det här fältet ska innehålla HTML-kod. Följande ersättare är tillgängliga:\n"
"\n"
"• #INVITATION_LINK (måste ingå) - Länken till mötesinbjudan\n"
"• #TITLE - Titeln på mötet\n"
"• #DESCRIPTION - Beskrivning på mötet\n"
"• #DATE_AND_TIME - Datum och tid för mötet\n"
"• #ACCEPT_LINK - Länk för att acceptera inbjudan\n"
"• #DECLINE_LINK - Länk för att neka inbjudan"

