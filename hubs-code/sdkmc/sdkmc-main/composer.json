{
  "name": "nextcloud/sdkmc",
  "description": "💌 A SDK Message Client app for Nextcloud",
  "type": "project",
  "license": "AGPL-3.0-or-later",
  "authors": [
    {
      "name": "ITSL",
      "email": "info@itsl.se"
    }
  ],
  "require": {
    "php": "^8.2",
    "ext-json": "*",
    "symfony/string": "^7.3"
  },
  "require-dev": {
    "nextcloud/ocp": "dev-stable30",
    "roave/security-advisories": "dev-latest",
    "bamarni/composer-bin-plugin": "^1.8.2",
    "nextcloud/coding-standard": "^v1.3.2",
    "php-parallel-lint/php-parallel-lint": "^1.4.0",
    "php-parallel-lint/php-console-highlighter": "^1.0.0",
    "phpstan/phpstan": "^2.1.11",
    "phpstan/phpstan-strict-rules": "^2.0.4",
    "phpstan/extension-installer": "^1.4.3",
    "phpstan/phpstan-deprecation-rules": "^2.0.1",
    "phpmd/phpmd": "^2.15.0",
    "squizlabs/php_codesniffer": "^3.12.1",
    "php-cs-fixer/shim": "^3.75.0"
  },
  "scripts": {
    "post-install-cmd": [
      "@composer bin all install --ansi"
    ],
    "post-update-cmd": [
      "@composer bin all update --ansi"
    ],
    "syntax": "php vendor/bin/parallel-lint appinfo/ lib/ templates/ docker/nextcloud/config.php .php-cs-fixer.dist.php",
    "phpmd": "php vendor/bin/phpmd appinfo/ lib/ templates/ docker/nextcloud/config.php .php-cs-fixer.dist.php text ./phpmd.xml",
    "phpstan": "php vendor/bin/phpstan analyse -c phpstan.neon --memory-limit=512M",
    "lint": [
        "@syntax",
        "@cs:check",
        "@phpmd",
        "@phpstan"
    ],
    "cs:check": "php-cs-fixer fix --dry-run --diff",
    "cs:fix": "php-cs-fixer fix"
  },
  "config": {
    "allow-plugins": {
      "bamarni/composer-bin-plugin": true,
      "composer/package-versions-deprecated": true,
      "phpstan/extension-installer": true
    },
    "platform": {
      "php": "8.2"
    },
    "optimize-autoloader": true,
    "sort-packages": true
  }
}
