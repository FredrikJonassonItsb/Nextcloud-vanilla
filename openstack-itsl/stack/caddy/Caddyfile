# Caddyfile — TLS termination + path routing for the five brains (CONTRACTS §4)
# Cert files come from ${CERT_DIR} on the host, mounted read-only at /certs
# (deploy.sh copies the dev15 LE cert covering dev15.hubs.se, or generates a
# self-signed fallback). handle_path strips the /<agent> prefix, so
# https://dev15.hubs.se:8843/reb/mcp -> http://brain-reb:7101/mcp

{
	admin off
	auto_https off
}

:8843 {
	tls /certs/fullchain.pem /certs/privkey.pem
	encode zstd gzip

	# caddy self-health (no upstream involved) — used by the docker healthcheck
	handle /ping {
		respond "ok" 200
	}

	# aggregate health: one internal subrequest per brain via httpInclude.
	# 200 + per-brain status lines when all brains answer; 500 if any
	# subrequest fails hard (template error) — either way a single URL to probe.
	handle /healthz {
		root * /etc/caddy
		templates {
			mime text/plain
		}
		rewrite * /healthz.txt
		file_server
	}

	handle_path /reb/* {
		reverse_proxy brain-reb:7101
	}
	handle_path /atlas/* {
		reverse_proxy brain-atlas:7102
	}
	handle_path /ada/* {
		reverse_proxy brain-ada:7103
	}
	handle_path /marvin/* {
		reverse_proxy brain-marvin:7104
	}
	handle_path /team/* {
		reverse_proxy brain-team:7105
	}

	handle {
		respond "Not found" 404
	}
}
