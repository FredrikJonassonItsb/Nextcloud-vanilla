# =============================================================================
# ITSL Open Stack — .env.example (CONTRACTS §8, fullständig lista)
#
# Den riktiga filen ligger på servern: /opt/openstack/.env (chmod 600).
# Nycklar checkas ALDRIG in i git. deploy.sh genererar alla "genereras"-värden
# med `openssl rand -hex 32` om de saknas — befintliga värden skrivs aldrig över.
# =============================================================================

# ── Brain-nycklar (bearer-auth mot resp. openbrain-svc-instans) ──────────────
# 32 byte hex. Genereras av deploy.sh vid första deploy.
BRAIN_KEY_REB=
BRAIN_KEY_ATLAS=
BRAIN_KEY_ADA=
BRAIN_KEY_MARVIN=
BRAIN_KEY_TEAM=

# ── Externa API-nycklar ──────────────────────────────────────────────────────
# FREDRIK: fyll i din OpenRouter-nyckel (embeddings). Tom nyckel = pending-läge:
# tankar sparas med embedding=NULL och backfillas när nyckeln finns (CONTRACTS §5).
OPENROUTER_API_KEY=
# FREDRIK: fyll i runner-nyckeln från Anthropic-workspacen "hubs-openstack-runner".
# Tom nyckel = runnerns cron kör INTE (gate i CONTRACTS §4/§7).
ANTHROPIC_API_KEY=

# ── agent_engine ↔ runner ────────────────────────────────────────────────────
# 32 byte hex. Genereras av deploy.sh. Samma värde sätts i Nextcloud med:
#   occ config:app:set agent_engine engine_push_secret --value <värdet>
ENGINE_PUSH_SECRET=

# ── Talk-bot-secrets (HMAC per rum-bot, CONTRACTS §6) ────────────────────────
# 32 byte hex. Genereras av deploy.sh. Samma värde används vid
#   occ talk:bot:install "<namn> (agent)" <secret> http://10.43.51.62:8790/bot
TALK_BOT_SECRET_REB=
TALK_BOT_SECRET_ATLAS=
TALK_BOT_SECRET_ADA=
TALK_BOT_SECRET_MARVIN=

# ── Nextcloud ────────────────────────────────────────────────────────────────
NC_BASE=https://dev15.hubs.se

# Bot-användarnas app-lösenord. Genereras av provision/occ-provision.sh
# (occ user:auth-tokens:add) och klistras in här — INTE av deploy.sh.
BOT_APP_PASSWORD_REB=
BOT_APP_PASSWORD_ATLAS=
BOT_APP_PASSWORD_ADA=
BOT_APP_PASSWORD_MARVIN=
BOT_APP_PASSWORD_ENGINE=

# ── Runner ───────────────────────────────────────────────────────────────────
# 0 tills OPENROUTER_API_KEY + ANTHROPIC_API_KEY är satta och smoke-01..06 är gröna.
RUNNER_ENABLED=0
# Dagstak i USD per agent; överskridet => slot pausad + larm i Talk-rummet "Agent Ops".
RUNNER_DAILY_USD_CAP=10

# ── Embeddings ───────────────────────────────────────────────────────────────
EMBED_MODEL=openai/text-embedding-3-small

# ── Infrastruktur (används av compose; inte del av CONTRACTS §8:s API-yta) ───
# Postgres superuser-lösenord för brain-db. Genereras av deploy.sh.
POSTGRES_PASSWORD=
# Per-databas-rollösenord (u_reb..u_team, svc_engine). Genereras av deploy.sh.
DB_PASS_REB=
DB_PASS_ATLAS=
DB_PASS_ADA=
DB_PASS_MARVIN=
DB_PASS_TEAM=
DB_PASS_ENGINE=
# Katalog med fullchain.pem + privkey.pem för caddy (:8843).
# Sätts/uppdateras av deploy.sh: kopia av dev15:s LE-cert som täcker
# dev15.hubs.se, annars self-signed fallback. Normalt /opt/openstack/certs.
CERT_DIR=
