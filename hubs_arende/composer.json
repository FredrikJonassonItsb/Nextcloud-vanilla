{
    "name": "itsl/hubs_arende",
    "description": "Hubs Ärende — fristående ärende-motor (koordinations-state, register och routing) för Hubs/ITSL.",
    "type": "project",
    "license": "AGPL-3.0-or-later",
    "authors": [
        {
            "name": "ITSL",
            "email": "info@itsl.se"
        }
    ],
    "require": {
        "php": ">=8.1"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5",
        "nextcloud/ocp": "^31.0",
        "psr/log": "^3.0",
        "psr/container": "^2.0"
    },
    "autoload-dev": {
        "psr-4": {
            "OCA\\HubsArende\\Tests\\": "tests/"
        }
    },
    "config": {
        "sort-packages": true,
        "optimize-autoloader": true
    },
    "scripts": {
        "test": "phpunit -c phpunit.xml",
        "lint": "find lib -name '*.php' -print0 | xargs -0 -n1 php -l"
    }
}
