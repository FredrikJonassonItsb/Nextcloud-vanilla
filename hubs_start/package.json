{
  "name": "hubs_start",
  "version": "1.0.0",
  "description": "Hubs Start — Flödesnavet, den samlade förstavyn för säker kommunikation",
  "license": "AGPL-3.0-or-later",
  "private": true,
  "engines": {
    "node": "^20.0.0",
    "npm": "^10.0.0"
  },
  "scripts": {
    "build": "NODE_ENV=production webpack --config webpack.js --progress",
    "dev": "NODE_ENV=development webpack --config webpack.js --progress",
    "watch": "NODE_ENV=development webpack --config webpack.js --progress --watch",
    "lint": "eslint \"src/**/*.{js,vue}\"",
    "lint:fix": "eslint \"src/**/*.{js,vue}\" --fix",
    "stylelint": "stylelint \"src/**/*.{css,scss,vue}\"",
    "stylelint:fix": "stylelint \"src/**/*.{css,scss,vue}\" --fix",
    "test": "jest",
    "test:watch": "jest --watch"
  },
  "browserslist": [
    "extends @nextcloud/browserslist-config"
  ],
  "dependencies": {
    "@nextcloud/auth": "^2.5.2",
    "@nextcloud/axios": "^2.5.1",
    "@nextcloud/dialogs": "^5.3.8",
    "@nextcloud/initial-state": "^2.2.0",
    "@nextcloud/l10n": "^3.1.0",
    "@nextcloud/router": "^3.0.1",
    "@nextcloud/vue": "^8.11.2",
    "vue": "^2.7.16",
    "vue-material-design-icons": "^5.3.1",
    "vue-router": "^3.6.5"
  },
  "devDependencies": {
    "@babel/preset-env": "^7.29.7",
    "@nextcloud/browserslist-config": "^3.0.1",
    "@nextcloud/eslint-config": "^8.4.2",
    "@nextcloud/eslint-plugin": "^2.2.1",
    "@nextcloud/stylelint-config": "^2.4.0",
    "@nextcloud/webpack-vue-config": "^5.5.1",
    "@vue/test-utils": "^1.3.6",
    "babel-core": "^7.0.0-bridge.0",
    "babel-jest": "^29.7.0",
    "eslint": "^8.57.1",
    "eslint-plugin-vue": "^9.33.0",
    "eslint-webpack-plugin": "^4.1.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "stylelint-webpack-plugin": "^5.0.0",
    "vue-jest": "^3.0.7",
    "vue-loader": "^15.11.1"
  }
}
